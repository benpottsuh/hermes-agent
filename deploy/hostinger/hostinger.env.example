# Usually created by: ./deploy/hostinger/bootstrap.sh
# SSH_HOST must match a Host block in ~/.ssh/config

SSH_HOST=hermes-hostinger
HOSTINGER_VM_ID=
HOSTINGER_VPS_IP=
DOCKER_PROJECT=
DOCKER_CONTAINER=
SSH_USER=root

HERMES_INSTALL=/opt/hermes
HERMES_USER=hermes
HERMES_DATA=/home/hermes/.hermes

# How to restart gateway after deploy (used by sync.sh later)
GATEWAY_RESTART_CMD='sudo -u hermes /opt/hermes/.venv/bin/hermes gateway restart || /opt/data/scripts/hermes-gateway-watchdog.sh'
